# 使用 OpenJDK 作为基础镜像
FROM openjdk:11-jre-slim

RUN sed -i 's|deb.debian.org|mirrors.aliyun.com|g' /etc/apt/sources.list

# RUN (crontab -l 2>/dev/null; echo "10 17 * * * /vms/sdb/lhd/anaconda3/envs/pytorch/bin/python /vms/sdb/lhd/code/paper/stock/analysis/demo/core/dataupdate.py >> /vms/sdb/lhd/code/paper/stock/analysis/demo/core/dataAnalysis.log 2>&1") | crontab -

# 安装 Python 和 pip
RUN apt-get update && \
    apt-get install -y python3 python3-pip cron vim && \
    rm -rf /var/lib/apt/lists/*

RUN echo "Asia/Shanghai" > /etc/timezone && \
    ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime

# RUN (crontab -l 2>/dev/null; echo "10 17 * * * python /vms/sdb/lhd/code/paper/stock/analysis/demo/core/dataupdate.py >> /vms/sdb/lhd/code/paper/stock/analysis/demo/core/dataAnalysis.log 2>&1") | crontab -

# 创建 python 到 python3 的符号链接
RUN ln -sf /usr/bin/python3 /usr/bin/python

# 安装 Python 依赖包
RUN pip3 install --upgrade pip -i https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple
RUN pip3 install pymysql tushare fire cryptography -i https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple

